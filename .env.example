# Backend URL used by SvelteKit's server-side load (SSR) and the Vite dev proxy.
# In production, set this to wherever the backend is reachable from the SvelteKit
# Node process (e.g. http://backend:8080 in a docker-compose network).
# Browser code does NOT use this — it talks to /api/* on the same origin and
# relies on a reverse proxy (nginx/Caddy in prod, Vite proxy in dev) to route
# those requests to the backend.
API_BASE_URL=http://localhost:8080
