# Backend URL used by SvelteKit's server-side proxy and SSR loaders. The
# browser never uses this — it talks to /api/* on the same origin and the
# SvelteKit catch-all (src/routes/api/[...path]/+server.ts) forwards to here
# after attaching the Bearer token from the session cookie.
API_BASE_URL=http://localhost:8080

# Keycloak OIDC issuer for the `palaisdivin` realm. The SvelteKit server
# discovers authorize/token/end_session endpoints from
# `${KEYCLOAK_ISSUER_URI}/.well-known/openid-configuration`.
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/palaisdivin

# Public OIDC client id registered in the realm. PKCE flow, no secret.
OIDC_CLIENT_ID=palais-divin-frontend

# Public origin of this SvelteKit app. Used to build the redirect_uri sent
# to Keycloak — must match a redirect URI whitelisted in the realm.
PUBLIC_ORIGIN=http://localhost:5173

# 32+ random bytes (base64) used as the AES-256-GCM key for encrypting the
# session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET=
